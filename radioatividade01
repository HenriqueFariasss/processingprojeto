// ============================================================
// RADIOATIVA — Energia Nuclear Interativa
// Projeto Processing — Tela Inicial + Abas + Transições
// ============================================================

import java.util.*;

// ---------- Estado Global ----------
int currentScreen = 0;   // 0=Home, 1=Sobre, 2=Tipos, 3=Reator, 4=Perigos, 5=Animação
int targetScreen  = 0;
float transAlpha  = 0;   // 0..255 para fade
boolean fading    = false;
boolean fadeIn    = false;
int pendingScreen = 0;

// ---------- Partículas da Home ----------
Particle[] particles = new Particle[120];
float rotAngle = 0;
float pulseVal = 0;

// ---------- Reator (aba 3) ----------
ReactorSim reactor;

// ---------- Animação (aba 5) ----------
AnimacaoSim animacao;

// ---------- Cores Globais ----------
color COL_BG      = #0a0f0a;
color COL_GREEN   = #39ff14;
color COL_YELLOW  = #c8ff00;
color COL_ORANGE  = #ff6600;
color COL_RED     = #ff1a1a;
color COL_DARK    = #0d1a0d;
color COL_PANEL   = #111811;

// ---------- Fontes ----------
PFont fontMono;
PFont fontTitle;

// ---------- Scroll (abas de texto) ----------
float scrollY     = 0;
float targetScrollY = 0;

// ============================================================
void setup() {
  fullScreen();
  smooth(8);

  fontMono  = createFont("Courier New", 14, true);
  fontTitle = createFont("Courier New", 48, true);

  for (int i = 0; i < particles.length; i++) {
    particles[i] = new Particle();
  }
  reactor = new ReactorSim();
  animacao = new AnimacaoSim();
}

// ============================================================
void draw() {
  background(COL_BG);

  // Atualiza fade
  if (fading) {
    if (!fadeIn) {
      transAlpha += 12;
      if (transAlpha >= 255) {
        transAlpha = 255;
        currentScreen = pendingScreen;
        scrollY = 0; targetScrollY = 0;
        fadeIn = true;
      }
    } else {
      transAlpha -= 12;
      if (transAlpha <= 0) {
        transAlpha = 0;
        fading = false;
        fadeIn = false;
      }
    }
  }

  // Renderiza tela atual
  switch(currentScreen) {
    case 0: drawHome();    break;
    case 1: drawSobre();   break;
    case 2: drawTipos();   break;
    case 3: drawReator();  break;
    case 4: drawPerigos(); break;
    case 5: drawAnimacao(); break;
  }

  // Navbar (todas as telas exceto home)
  if (currentScreen != 0) drawNavbar();

  // Overlay de fade
  if (fading || transAlpha > 0) {
    noStroke();
    fill(10, 25, 10, transAlpha);
    rect(0, 0, width, height);

    // Cruz radioativa no centro durante transição
    if (transAlpha > 100) {
      drawRadSymbolCenter(transAlpha);
    }
  }

  pulseVal += 0.04;
  rotAngle  += 0.008;
}

// ============================================================
// HOME
// ============================================================
void drawHome() {
  // Fundo com gradiente radial via pontos
  for (int r = 300; r > 0; r -= 4) {
    float a = map(r, 0, 300, 80, 0);
    fill(30, 80, 20, a);
    noStroke();
    ellipse(width/2, height/2, r*2, r*2);
  }

  // Partículas
  for (Particle p : particles) {
    p.update();
    p.display();
  }

  // Símbolo radioativo central girando
  pushMatrix();
  translate(width/2, height/2 - 20);
  rotate(rotAngle);
  float sc = 1.0 + 0.06 * sin(pulseVal);
  scale(sc);
  drawRadSymbol(90, COL_GREEN, 180);
  popMatrix();

  // Título
  float glow = 0.5 + 0.5 * sin(pulseVal * 1.3);
  textFont(fontTitle);
  textAlign(CENTER, CENTER);

  // sombra / glow
  for (int g = 8; g > 0; g--) {
    fill(57, 255, 20, (int)(18 * glow * g / 8.0));
    text("RADIOATIVA", width/2 + g*0.5, height/2 + 120 + g*0.5);
  }
  fill(COL_GREEN);
  text("RADIOATIVA", width/2, height/2 + 120);

  textFont(fontMono);
  textSize(13);
  fill(COL_YELLOW, 200);
  text("▸ Energia Nuclear Interativa ◂", width/2, height/2 + 158);

  // Botões de menu
  String[] labels = {"SOBRE RADIAÇÃO", "TIPOS DE RADIAÇÃO", "SIMULADOR DE REATOR", "RISCOS E SEGURANÇA", "ANIMAÇÃO INTERATIVA"};
  int[] targets   = {1, 2, 3, 4, 5};
  int bw = 200, bh = 42, gap = 12;
  int startX = width/2 - bw - gap/2;
  int startY = height/2 + 190;

  for (int i = 0; i < labels.length; i++) {
    int bx, by;
    if (i < 4) {
      int col = i % 2; int row = i / 2;
      bx = startX + col * (bw + gap);
      by = startY + row * (bh + gap);
    } else {
      bx = width/2 - bw/2;
      by = startY + 2 * (bh + gap);
    }
    drawMenuButton(bx, by, bw, bh, labels[i], targets[i]);
  }

  // Footer
  textSize(10);
  fill(COL_GREEN, 80);
  textAlign(CENTER, BOTTOM);
  text("☢  Clique num botão para explorar  ☢", width/2, height - 10);
}

void drawMenuButton(int x, int y, int w, int h, String label, int target) {
  boolean over = mouseX > x && mouseX < x+w && mouseY > y && mouseY < y+h;
  float glowA = over ? 1.0 : 0.4 + 0.3 * sin(pulseVal + target);

  // Borda
  stroke(COL_GREEN, (int)(200 * glowA));
  strokeWeight(over ? 2.0 : 1.0);
  fill(COL_DARK, over ? 230 : 180);
  rect(x, y, w, h, 4);

  // Indicador lateral
  noStroke();
  fill(COL_GREEN, (int)(180 * glowA));
  rect(x, y + h/2 - 8, 3, 16, 2);

  // Texto
  textFont(fontMono);
  textSize(11);
  textAlign(LEFT, CENTER);
  fill(over ? COL_YELLOW : COL_GREEN, (int)(230 * glowA));
  text("▸  " + label, x + 14, y + h/2);
}

// ============================================================
// NAVBAR
// ============================================================
void drawNavbar() {
  // Fundo da barra
  noStroke();
  fill(COL_PANEL);
  rect(0, 0, width, 44);
  stroke(COL_GREEN, 60);
  strokeWeight(1);
  line(0, 44, width, 44);

  // Botão HOME
  drawNavBtn(10, 8, 70, 28, "☢ HOME", 0, currentScreen == 0);

  String[] navLabels  = {"SOBRE", "TIPOS", "REATOR", "PERIGOS", "ANIMAÇÃO"};
  int[]    navTargets = {1, 2, 3, 4, 5};
  int nx = 90;
  for (int i = 0; i < navLabels.length; i++) {
    drawNavBtn(nx, 8, 95, 28, navLabels[i], navTargets[i], currentScreen == navTargets[i]);
    nx += 102;
  }
}

void drawNavBtn(int x, int y, int w, int h, String label, int target, boolean active) {
  boolean over = mouseX > x && mouseX < x+w && mouseY > y && mouseY < y+h;
  noStroke();
  if (active) {
    fill(COL_GREEN, 40);
    rect(x, y, w, h, 3);
    stroke(COL_GREEN, 180);
    strokeWeight(1);
    noFill();
    rect(x, y, w, h, 3);
  } else if (over) {
    fill(COL_GREEN, 20);
    rect(x, y, w, h, 3);
  }
  textFont(fontMono);
  textSize(11);
  textAlign(CENTER, CENTER);
  fill(active ? COL_GREEN : (over ? COL_YELLOW : color(150, 200, 150)));
  text(label, x + w/2, y + h/2);
}

