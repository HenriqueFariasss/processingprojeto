// ============================================================
// HELPERS DE DESENHO
// ============================================================
void drawRadSymbol(float r, color c, int alpha) {
  noStroke();
  // Círculo central
  fill(c, alpha);
  ellipse(0, 0, r*0.3, r*0.3);

  // 3 setores
  for (int i = 0; i < 3; i++) {
    pushMatrix();
    rotate(TWO_PI / 3 * i);
    fill(c, alpha);
    arc(0, 0, r*2, r*2, radians(30), radians(90));
    popMatrix();
  }

  // Anel externo vazio
  stroke(c, alpha);
  strokeWeight(3);
  noFill();
  ellipse(0, 0, r*2.2, r*2.2);
}

void drawRadSymbolCenter(float a) {
  pushMatrix();
  translate(width/2, height/2);
  rotate(rotAngle * 2);
  float sc = map(a, 100, 255, 0, 1);
  scale(sc);
  drawRadSymbol(30, COL_GREEN, (int)(a * 0.8));
  popMatrix();
}

void drawAtomDiagram(int cx, int cy, int r) {
  pushMatrix();
  translate(cx, cy);

  // Órbitas
  stroke(COL_GREEN, 60);
  strokeWeight(1);
  noFill();
  for (int i = 1; i <= 3; i++) {
    pushMatrix();
    rotate(rotAngle * i * 0.4);
    ellipse(0, 0, r * i * 0.7, r * i * 0.35);
    popMatrix();
  }

  // Elétrons nas órbitas
  for (int i = 1; i <= 3; i++) {
    pushMatrix();
    rotate(rotAngle * i * 0.4);
    float ex = cos(rotAngle * 2 * i) * r * i * 0.35;
    float ey = sin(rotAngle * 2 * i) * r * i * 0.175;
    noStroke();
    fill(COL_YELLOW);
    ellipse(ex, ey, 7, 7);
    popMatrix();
  }

  // Núcleo
  for (int g = 20; g > 0; g -= 2) {
    fill(COL_RED, 15);
    ellipse(0, 0, g*2, g*2);
  }
  fill(COL_RED);
  ellipse(0, 0, 18, 18);
  textFont(fontMono);
  textSize(9);
  textAlign(CENTER, CENTER);
  fill(255);
  text("n+p", 0, 0);

  textSize(11);
  fill(COL_GREEN, 180);
  textAlign(CENTER, TOP);
  text("Modelo atômico simplificado", 0, r + 10);

  popMatrix();
}

void drawPenetrationDiagram(int x, int y, int w) {
  int layers = 5;
  int lw = w / layers;
  String[] names = {"AR", "PAPEL", "ALUMÍNIO", "VIDRO/Pb", "CONCRETO"};
  color[] lCols = {color(30, 60, 30), color(80, 60, 20), color(60, 80, 60), color(20, 40, 80), color(60, 60, 60)};

  int dh = 90;
  for (int i = 0; i < layers; i++) {
    noStroke();
    fill(lCols[i]);
    rect(x + i*lw, y, lw, dh);
    textFont(fontMono);
    textSize(9);
    textAlign(CENTER, BOTTOM);
    fill(200, 230, 200, 180);
    text(names[i], x + i*lw + lw/2, y + dh - 4);
  }

  // Setas de radiação
  String[] radTypes = {"α", "β", "γ"};
  float[] stops = {0.08, 0.35, 0.92};
  color[] rCols = {COL_ORANGE, COL_YELLOW, COL_GREEN};
  for (int i = 0; i < 3; i++) {
    float arrowY = y + 18 + i * 20;
    float endX   = x + w * stops[i];
    stroke(rCols[i], 220);
    strokeWeight(2);
    line(x, arrowY, endX, arrowY);
    // arrowhead
    line(endX, arrowY, endX - 8, arrowY - 5);
    line(endX, arrowY, endX - 8, arrowY + 5);
    textFont(fontMono);
    textSize(11);
    textAlign(LEFT, CENTER);
    fill(rCols[i]);
    text(radTypes[i], x - 18, arrowY);
  }
}

void sectionHeader(int x, int y, String label) {
  stroke(COL_GREEN, 100);
  strokeWeight(1);
  line(x, y + 24, width - 60, y + 24);
  textFont(fontMono);
  textSize(15);
  textAlign(LEFT, BOTTOM);
  fill(COL_GREEN, 230);
  text(label, x, y + 22);
}

void bodyText(int x, int y, int w, String txt) {
  textFont(fontMono);
  textSize(12);
  textAlign(LEFT, TOP);
  fill(190, 220, 190, 220);
  drawWrappedText(txt, x, y, w, 16);
}

void drawWrappedText(String txt, float x, float y, float maxW, float lineH) {
  String[] lines = txt.split("\n");
  float curY = y;
  for (String line : lines) {
    String[] words = line.split(" ");
    String curLine = "";
    for (String word : words) {
      String test = curLine.isEmpty() ? word : curLine + " " + word;
      if (textWidth(test) > maxW) {
        text(curLine, x, curY);
        curY += lineH;
        curLine = word;
      } else {
        curLine = test;
      }
    }
    if (!curLine.isEmpty()) text(curLine, x, curY);
    curY += lineH;
  }
}

