class Particle {
  float x, y, vx, vy, sz, life, maxLife, alpha;
  color c;

  Particle() { reset(); }

  void reset() {
    float ang = random(TWO_PI);
    float rad = random(40, 220);
    x = width/2 + cos(ang) * rad;
    y = height/2 - 20 + sin(ang) * rad;
    float speed = random(0.3, 1.2);
    float outAng = ang + random(-0.4, 0.4);
    vx = cos(outAng) * speed;
    vy = sin(outAng) * speed;
    sz = random(2, 6);
    maxLife = random(80, 200);
    life = maxLife;
    int t = (int)random(3);
    c = t == 0 ? COL_GREEN : t == 1 ? COL_YELLOW : COL_ORANGE;
  }

  void update() {
    x += vx; y += vy;
    life--;
    if (life <= 0 || x < 0 || x > width || y < 0 || y > height) reset();
  }

  void display() {
    float a = map(life, 0, maxLife, 0, 220);
    noStroke();
    fill(c, a * 0.4);
    ellipse(x, y, sz * 2.5, sz * 2.5);
    fill(c, a);
    ellipse(x, y, sz, sz);
  }
}
