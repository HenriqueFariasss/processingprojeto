void drawRadCard(int x, int y, int w, int h, String[] data) {
  color c = unhex("FF" + data[2].substring(1));
  boolean over = mouseX > x && mouseX < x+w && mouseY > y && mouseY < y+h;
  float sc = over ? 1.012 : 1.0;

  pushMatrix();
  translate(x + w/2, y + h/2);
  scale(sc);
  translate(-(w/2), -(h/2));

  // Fundo
  noStroke();
  fill(10, 25, 10, 220);
  rect(0, 0, w, h, 6);

  // Borda colorida
  stroke(c, over ? 255 : 150);
  strokeWeight(over ? 2 : 1);
  noFill();
  rect(0, 0, w, h, 6);

  // Símbolo grande
  textFont(fontTitle);
  textSize(54);
  textAlign(CENTER, TOP);
  fill(c, over ? 255 : 180);
  text(data[0], w/2, 10);

  // Nome
  textFont(fontMono);
  textSize(13);
  fill(c);
  text(data[1], w/2, 72);

  // Descrição
  textSize(11);
  textAlign(LEFT, TOP);
  fill(200, 230, 200, 210);
  drawWrappedText(data[3], 14, 96, w - 28, 14);

  popMatrix();
}

void drawComparativeBar(int x, int y, int w) {
  String[] types = {"ALFA (α)", "BETA (β)", "GAMA (γ)", "NÊUTRON (n)"};
  float[] vals   = {0.05, 0.25, 0.85, 0.95};
  color[] cols   = {COL_ORANGE, COL_YELLOW, COL_GREEN, #00cfff};
  int bh = 28, gap = 10;

  for (int i = 0; i < types.length; i++) {
    int by = y + i * (bh + gap);
    textFont(fontMono);
    textSize(11);
    textAlign(LEFT, CENTER);
    fill(200, 230, 200);
    text(types[i], x, by + bh/2);

    int barX = x + 120;
    int barW = w - 130;

    // fundo
    noStroke();
    fill(30, 50, 30);
    rect(barX, by, barW, bh, 3);

    // barra
    float fw = barW * vals[i];
    float anim = fw * (0.9 + 0.1 * sin(pulseVal + i));
    fill(cols[i], 200);
    rect(barX, by, anim, bh, 3);

    // % texto
    textSize(10);
    textAlign(RIGHT, CENTER);
    fill(cols[i]);
    text(nf(vals[i]*100, 0, 0) + "%", barX + barW - 6, by + bh/2);
  }
}

