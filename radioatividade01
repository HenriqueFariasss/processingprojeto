void mousePressed() {
  // Botões da Home
  if (currentScreen == 0) {
    String[] labels = {"SOBRE RADIAÇÃO", "TIPOS DE RADIAÇÃO", "SIMULADOR DE REATOR", "RISCOS E SEGURANÇA", "ANIMAÇÃO INTERATIVA"};
    int[] targets   = {1, 2, 3, 4, 5};
    int bw = 200, bh = 42, gap = 12;
    int startX = width/2 - bw - gap/2;
    int startY = height/2 + 190;
    for (int i = 0; i < targets.length; i++) {
      int bx, by;
      if (i < 4) {
        int col = i % 2, row = i / 2;
        bx = startX + col * (bw + gap);
        by = startY + row * (bh + gap);
      } else {
        bx = width/2 - bw/2;
        by = startY + 2 * (bh + gap);
      }
      if (mouseX > bx && mouseX < bx+bw && mouseY > by && mouseY < by+bh) {
        goTo(targets[i]); return;
      }
    }
  }

  // Navbar
  if (currentScreen != 0) {
    if (mouseX > 10 && mouseX < 80 && mouseY > 8 && mouseY < 36) { goTo(0); return; }
    int[] nTargets = {1, 2, 3, 4, 5};
    int nx = 90;
    for (int t : nTargets) {
      if (mouseX > nx && mouseX < nx+95 && mouseY > 8 && mouseY < 36) { goTo(t); return; }
      nx += 102;
    }
  }

  // Reator: controles
  if (currentScreen == 3) reactor.handleClick(mouseX, mouseY);

  // Animação: controles
  if (currentScreen == 5) animacao.handleClick(mouseX, mouseY);
}

